[Unit]
Description=Check arbitrage readiness and fail closed
After=arbitrage-engine.service

[Service]
Type=oneshot
User=root
EnvironmentFile=/etc/arbitrage/arbitrage.env
ExecStart=/opt/arbitrage/current/ops/health_watchdog.sh
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/run /var/lib/arbitrage
